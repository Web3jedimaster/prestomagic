{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "claude-mem@thedotmack": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(./package-lock.json)",
      "Read(./node_modules/**)"
    ]
  }
}
